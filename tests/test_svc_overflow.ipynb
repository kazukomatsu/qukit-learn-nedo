 "cells": [
  {
   "cell_type": "markdown",
   "id": "1aa44f48",
   "metadata": {},
   "source": [
    "## How to Reproduce the OverflowError in SVC"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "22808032",
   "metadata": {},
   "source": [
    "### Preparation for performing SVC"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "39427a0c",
   "metadata": {},
   "outputs": [],
   "source": [
    "from qklearn.svm import SVC as QSVC\n",
    "from sklearn.svm import SVC as SSVC\n",
    "from sklearn.metrics import accuracy_score\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "import clustbench  # for using benchmarks\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "# for using Fixstars Amplify SDK\n",
    "from amplify import FixstarsClient\n",
    "from datetime import timedelta\n",
    "from qklearn.utils import read_token"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d538b9db",
   "metadata": {},
   "source": [
    "Note: Please place `amplify-license.yaml` in the same directory as this notebook in advance."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "60b17ecb",
   "metadata": {},
   "outputs": [],
   "source": [
    "client = FixstarsClient()\n",
    "client.token = read_token(\"Fixstars\")\n",
    "client.parameters.timeout = timedelta(milliseconds=5000)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "3f3721a2",
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_results(title, inputs, targets):\n",
    "    scatter = plt.scatter(inputs[:,0], inputs[:,1], c=targets, cmap='Accent')\n",
    "    plt.title(title)\n",
    "\n",
    "    # create a legend with unique labels\n",
    "    handles = []\n",
    "    labels = []\n",
    "    for label in set(targets):\n",
    "        handles.append(plt.Line2D([0], [0], marker='o', color='w', label=f'Cluster {label}',\n",
    "                                markerfacecolor=scatter.cmap(scatter.norm(label)), markersize=10))\n",
    "        labels.append(f'Cluster {label}')\n",
    "    plt.legend(handles=handles, title=\"Cluster Labels\")\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "04b5cb54",
   "metadata": {},
   "source": [
    "### Preparation of the Benchmark Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "e5e12e07",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "inputs.shape = (1016, 2)\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "data_url = \"https://github.com/gagolews/clustering-data-v1/raw/v1.1.0\"\n",
    "dataset_svc = clustbench.load_dataset(\"fcps\", \"wingnut\", url=data_url)\n",
    "inputs = dataset_svc.data\n",
    "n_clusters = dataset_svc.n_clusters[0]\n",
    "label_correct = dataset_svc.labels[0]\n",
    "label_correct[label_correct == 2] = -1\n",
    "\n",
    "print(f\"inputs.shape = {inputs.shape}\")\n",
    "title = dataset_svc.battery + \" / \" + dataset_svc.dataset\n",
    "plot_results(title, inputs, label_correct)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "49d5a8f8",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train, X_test, t_train, t_test = train_test_split(inputs, label_correct)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "11eef70b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "X_train.shape = (762, 2)\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "print(f\"X_train.shape = {X_train.shape}\")\n",
    "title = dataset_svc.battery + \" / \" + dataset_svc.dataset + \" train\"\n",
    "plot_results(title, X_train, t_train)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "6e6e9f34",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "X_test.shape = (254, 2)\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "print(f\"X_test.shape = {X_test.shape}\")\n",
    "title = dataset_svc.battery + \" / \" + dataset_svc.dataset\n",
    "plot_results(title, X_test, t_test)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "cd5508e7",
   "metadata": {},
   "source": [
    "### Execution of SVC with the Benchmark Dataset"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "819b0484",
   "metadata": {},
   "source": [
    "- Calculate the accuracy score using SVC of scikit-learn"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "7af24f3f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1.0\n"
     ]
    }
   ],
   "source": [
    "ssvc = SSVC()\n",
    "ssvc.fit(X_train, t_train)\n",
    "\n",
    "y_train_pred_slr = ssvc.predict(X_train)\n",
    "y_test_pred_slr = ssvc.predict(X_test)\n",
    "\n",
    "acc_sc = accuracy_score(t_test, y_test_pred_slr)\n",
    "print(acc_sc)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7608f15c",
   "metadata": {},
   "source": [
    "- Sweep the parameters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "0605976d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "k_max  9 , e_max  11 , acc_max  1.0\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "acc_max = 0\n",
    "k_max = 0\n",
    "e_max = 0\n",
    "list_exponent_offset = list(range(5, 15))\n",
    "\n",
    "for k in range(3, 10):\n",
    "  acc = np.zeros(10)\n",
    "  for i, e in enumerate(list_exponent_offset):\n",
    "    model = QSVC()\n",
    "    model.fit(X_train, t_train, client, num_elements=k, exponent_offset=e, xi=1)\n",
    "    y_pred = model.predict(X_test)\n",
    "    acc[i] = accuracy_score(t_test, y_pred)\n",
    "    if acc_max <= acc[i]:\n",
    "      acc_max = acc[i]\n",
    "      k_max = k\n",
    "      e_max = e\n",
    "\n",
    "  fig = plt.figure()\n",
    "  ax = fig.add_subplot(111)\n",
    "  ax.set_title(\"the number of elements \"+ str(k))\n",
    "  ax.set_xlabel(\"the exponent offset\")\n",
    "  ax.set_ylabel(\"accuracy\")\n",
    "  ax.set_xticks(list_exponent_offset)\n",
    "  ax.scatter(list_exponent_offset, acc, c ='blue')\n",
    "  ax.plot(list_exponent_offset, np.full(10, acc_sc), c='green')\n",
    "\n",
    "print(\"k_max \", k_max, \", e_max \", e_max, \", acc_max \", acc_max)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "05dfccc5",
   "metadata": {},
   "outputs": [],
   "source": [
    "qsvc = QSVC()\n",
    "qsvc.fit(X_train, t_train, client,\n",
    "            num_elements=k_max, exponent_offset=e_max, xi=1)\n",
    "y_train_pred_qlr = qsvc.predict(X_train)\n",
    "y_test_pred_qlr = qsvc.predict(X_test)\n",
    "assert(len(y_train_pred_qlr) == len(X_train))\n",
    "assert(len(y_test_pred_qlr) == len(X_test))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "05a155de",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1600x600 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "fig = plt.figure(figsize=(16, 6))\n",
    "ax1 = fig.add_subplot(1, 2, 1)\n",
    "ax2 = fig.add_subplot(1, 2, 2)\n",
    "\n",
    "ax1.set_title(\"Qklearn Train Data points of the 2 classes\")\n",
    "ax1.scatter(X_train[:,0], X_train[:,1], c=y_train_pred_qlr, cmap='winter')\n",
    "ax2.set_title(\"Qklearn Test Data points of the 2 classes\")\n",
    "ax2.scatter(X_test[:,0], X_test[:,1], c=y_test_pred_qlr, cmap='winter')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
