   "source": [
    "inputs_train = np.array([[1.0, 2.0], [3.0, 4.0]])\n",
    "targets_train = np.array([1, 1])\n",
    "inputs_test = np.array([[5.0, 2.0], [3.0, 7.0]])\n",
    "\n",
    "qsvc = QSVC()\n",
    "qsvc.fit(inputs_train, targets_train, client,\n",
    "            num_elements=k_max, exponent_offset=e_max, xi=1)\n",
    "y_train_pred_qlr = qsvc.predict(inputs_train)\n",
    "y_test_pred_qlr = qsvc.predict(inputs_test)\n",
    "\n",
    "fig = plt.figure(figsize=(16, 6))\n",
    "ax1 = fig.add_subplot(1, 2, 1)\n",
    "ax2 = fig.add_subplot(1, 2, 2)\n",
    "\n",
    "ax1.set_title(\"RuntimeWarning Train\")\n",
    "ax1.scatter(inputs_train[:,0], inputs_train[:,1], c=y_train_pred_qlr, cmap='winter')\n",
    "ax2.set_title(\"RuntimeWarning Test\")\n",
    "ax2.scatter(inputs_test[:,0], inputs_test[:,1], c=y_test_pred_qlr, cmap='winter')\n",
    "plt.show()"
   ]
  },
